using System;
using System.Collections.Generic;

public class HelloWorld
{
    public static void SprawdzenieWiekszychNizProg(int[] tab, int prog)
    {
        List<int> wieksze = new List<int>();
        for(int i = 0; i < tab.Length; i++)
        {
            if(tab[i] > prog)
            {
                wieksze.Add(tab[i]);
            }
        }
        Console.WriteLine("Liczby wieksze od podanego progu:");
        foreach(int elementy in wieksze)
        {
            Console.WriteLine(elementy);
        }
    }
    
    public static void Main(string[] args)
    {
        int prog = 12;
        int[] tablica = {1, 12, 16, 3, -5, 100, 12531, 0, 5, 7, 88};
        SprawdzenieWiekszychNizProg(tablica, prog);
    }
}
