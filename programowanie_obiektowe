        Console.WriteLine("Dlugosc 2 boku:");
        double bok2 = double.Parse(Console.ReadLine());
        Console.WriteLine("Dlugosc 3 boku:");
        double bok3 = double.Parse(Console.ReadLine());
        
        CzyJestProstokatny(bok1, bok2, bok3);
    }
}


