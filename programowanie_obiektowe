using System;

public class HelloWorld
{
    public static int[] WartosciPoczatkowe(int[] tablica, int prog)
    {
        if(tablica == null)
        {
            return new int[0];
        }
        
        int suma = 0;
        int ilosc = 0;
        
        for(int i = 0; i < tablica.Length; i++)
        {
            if(suma + tablica[i] <= prog)
            {
                suma += tablica[i];
                ilosc++;
            }
            else
            {
                break;
            }
        }
        
        int[] wynik = new int[ilosc];
        
        for(int i = 0; i < ilosc; i++)
        {
            wynik[i] = tablica[i];
        }
        
        return wynik;
    }
    public static void Main(string[] args)
    {
        int[] liczby = {1, 2, 3, 4, 5, 6, 7};
        int prog = 21;
        int[] poczatkowe = HelloWorld.WartosciPoczatkowe(liczby, prog);
        Console.WriteLine("Poczatkowe wartosci nie przekraczajace progu to: ");
        Console.WriteLine(string.Join(", ", poczatkowe));
    }
}


