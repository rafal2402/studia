using System;

public class HelloWorld
{
    public static void CzyJestProstokatny(double a, double b, double c)
    {
        if(a*a + b*b == c*c)
        {
            Console.WriteLine($"Trojkat o bokach {a}, {b}, {c} jest prostokatny.");
        }
        else
        {
           Console.WriteLine($"Trojkat o bokach {a}, {b}, {c} NIE jest prostokatny.");
        }
    }
    
    public static void Main(string[] args)
    {
        Console.WriteLine("Sprawdz czy trojkat jest prostokatny. Podaj dlugosci bokow.");
        Console.WriteLine("Dlugosc 1 boku:");
